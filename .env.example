# Public application origin used for OAuth redirects.
APP_URL=http://127.0.0.1:3000
VITE_EARLY_ACCESS_URL=mailto:info@adultgen.fun?subject=AdultGen%20AI%20Early%20Access

# Google OAuth web application credentials (server-side only).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:3000/api/google-callback
AUTH_SESSION_SECRET=

# OpenAI-compatible AdultGen model endpoint. Set after AWS deployment.
ADULTGEN_BACKEND_URL=
ADULTGEN_BACKEND_API_KEY=
ADULTGEN_MODEL=Qwen/Qwen3-4B-MLX-4bit
ADULTGEN_DEBUG=0

# Credential-protected investor demo.
INVESTOR_LOGIN=
INVESTOR_PASSWORD=
INVESTOR_PASSWORD_ALIASES=
INVESTOR_SESSION_SECRET=
